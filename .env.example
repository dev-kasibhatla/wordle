# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Harbor registry credentials (same names as GitHub Secrets)
HARBOR_REGISTRY=your-registry.example.com
HARBOR_PROJECT=your-project-name
HARBOR_USERNAME=robot-account-name
HARBOR_PASSWORD=your-robot-token

# Remote deployment settings
DEPLOY_HOST=your.server.example.com
DEPLOY_USER=deploy-user
DEPLOY_REMOTE_DIR=/opt/wordle
DEPLOY_HOST_PORT=8000
PRODUCTION_BASE_URL=https://wordle.example.com

# Optional: override the exposed port (default 8000)
PORT=8000

# Optional: trust X-Forwarded-For only from listed proxies
WORDLE_TRUST_PROXY_HEADERS=false
WORDLE_TRUSTED_PROXY_HOSTS=

# Optional: tune public rate limits
WORDLE_RATE_LIMIT_WINDOW_SECONDS=60
WORDLE_RATE_LIMIT_GAME_PER_IP=30
WORDLE_RATE_LIMIT_GAME_GLOBAL=300
WORDLE_RATE_LIMIT_SOLVER_PER_IP=10
WORDLE_RATE_LIMIT_SOLVER_GLOBAL=60
