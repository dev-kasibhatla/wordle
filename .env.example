# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
#
# Harbor registry credentials (same names as GitHub Secrets)
HARBOR_REGISTRY=your-registry.example.com
HARBOR_PROJECT=your-project-name
HARBOR_USERNAME=robot-account-name
HARBOR_PASSWORD=your-robot-token

# Optional: override the exposed port (default 8000)
PORT=8000
